<Window x:Class="TinyAcc.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TinyAcc Multi Game Instance"
        Width="320" SizeToContent="Height"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        Background="White"
        FontFamily="Tahoma" FontSize="12"
        Foreground="Black">

    <StackPanel Margin="16,14,16,16">
        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
            <Image Source="assets/tinyacc-instances-icon.png"
                   Width="34" Height="34"
                   VerticalAlignment="Center"
                   Margin="0,0,10,0"
                   RenderOptions.BitmapScalingMode="HighQuality"/>
            <Image Source="assets/tinyacc-wordmark.png"
                   Width="150" VerticalAlignment="Center"
                   RenderOptions.BitmapScalingMode="HighQuality"/>
        </StackPanel>

        <TextBlock x:Name="StatusText" FontWeight="Bold" Margin="0,0,0,6"/>
        <TextBlock x:Name="HintText" TextWrapping="Wrap" Foreground="#333"/>

        <StackPanel x:Name="Buttons" Orientation="Horizontal" Margin="0,12,0,0" Visibility="Collapsed">
            <Button x:Name="RetryBtn" Content="Retry" Width="80" Height="24"
                    Margin="0,0,8,0" Click="Retry_Click"/>
            <Button x:Name="ForceCloseBtn" Content="Close Roblox" Width="100" Height="24"
                    Click="ForceClose_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
